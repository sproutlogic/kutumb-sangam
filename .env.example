# ── Kutumb Sangam Frontend Environment Variables ──────────────────────────────
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.

# Supabase project URL (from Supabase Dashboard → Project Settings → API)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon/public key (safe to expose in frontend)
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Backend API base URL
# Development: http://localhost:8000
# Production:  https://api.kutumbmap.com  (or your App Runner URL)
VITE_API_BASE_URL=http://localhost:8000

# Default vansha_id for demo/dev mode (optional — leave blank in production)
VITE_DEFAULT_VANSHA_ID=

# Set to "true" to bypass plan gating during beta testing (NEVER in production)
VITE_BETA_ALL_ACCESS=false
