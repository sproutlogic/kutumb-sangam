# ── Kutumb Sangam Backend Environment Variables ───────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# Supabase project URL
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase SERVICE ROLE key (not the anon key — this bypasses RLS)
# Found in: Supabase Dashboard → Project Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase JWT secret (for verifying user tokens server-side)
# Found in: Supabase Dashboard → Project Settings → API → JWT Secret
SUPABASE_JWT_SECRET=your-jwt-secret-here

# APScheduler: matrimony gotra collision job schedule (cron format)
# Default: runs daily at 02:30
MATCHER_CRON_HOUR=2
MATCHER_CRON_MINUTE=30

# CORS allowed origins (comma-separated, no trailing slash)
# Development: http://localhost:5173,http://localhost:8080
# Production:  https://prakriti.ecotech.co.in
ALLOWED_ORIGINS=https://prakriti.ecotech.co.in
